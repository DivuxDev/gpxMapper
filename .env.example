# GPX Mapper - Variables de entorno

# Copia este archivo como .env.local y rellena tus claves reales
# NUNCA subas .env.local al repositorio

# GraphHopper API Key (https://graphhopper.com/)
VITE_GRAPHHOPPER_API_KEY=your_graphhopper_api_key_here

# Perfil de routing por defecto: foot, bike, mtb, racingbike, car
VITE_GH_DEFAULT_PROFILE=foot
